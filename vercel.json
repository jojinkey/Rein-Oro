{
  "$schema": "./.vscode/vercel.schema.json",
  "framework": "services",
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "routePrefix": "/",
      "framework": "vite",
      "installCommand": "npm ci",
      "buildCommand": "npm run build"
    },
    "backend": {
      "entrypoint": "backend/server.js",
      "routePrefix": "/api",
      "framework": "express",
      "installCommand": "npm ci",
      "buildCommand": "npm test",
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": {
        "type": "service",
        "service": "backend",
        "path": "/api/:path*"
      }
    },
    {
      "source": "/sitemap.xml",
      "destination": {
        "type": "service",
        "service": "backend",
        "path": "/sitemap.xml"
      }
    },
    {
      "source": "/robots.txt",
      "destination": {
        "type": "service",
        "service": "backend",
        "path": "/robots.txt"
      }
    },
    {
      "source": "/(.*)",
      "destination": {
        "type": "service",
        "service": "frontend",
        "path": "/$1"
      }
    }
  ]
}
