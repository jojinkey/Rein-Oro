{
  "framework": "services",
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "routePrefix": "/"
    },
    "backend": {
      "entrypoint": "backend/server.js",
      "routePrefix": "/api"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": {
        "type": "service",
        "service": "backend",
        "path": "/api/:path*"
      }
    },
    {
      "source": "/sitemap.xml",
      "destination": {
        "type": "service",
        "service": "backend",
        "path": "/sitemap.xml"
      }
    },
    {
      "source": "/robots.txt",
      "destination": {
        "type": "service",
        "service": "backend",
        "path": "/robots.txt"
      }
    },
    {
      "source": "/(.*)",
      "destination": {
        "type": "service",
        "service": "frontend",
        "path": "/$1"
      }
    }
  ]
}
